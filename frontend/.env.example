# ========================================
# FRONTEND ENVIRONMENT VARIABLES
# ========================================
# IMPORTANT: Copy this to .env.local and fill in YOUR values
# NEVER commit .env.local to Git - add it to .gitignore

# ─── API CONFIGURATION ────────────────────
# ⚠️ CRITICAL: This must be your ACTUAL deployed backend URL
# Examples:
#   - Render: https://sharemyride-backend.onrender.com/api
#   - Vercel: https://sharemyride-backend.vercel.app/api
#   - Custom: https://api.yourdomain.com/api
# ❌ DO NOT use http://localhost - this is for development only
VITE_API_URL=https://YOUR-BACKEND-DEPLOYED-URL.com/api

# ─── GOOGLE MAPS API KEY ──────────────────
# Get from: https://console.cloud.google.com/
# Must be same as backend GOOGLE_MAPS_API_KEY
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# ─── APP CONFIG ───────────────────────────
VITE_APP_NAME=ShareMyRide
VITE_APP_URL=https://YOUR-FRONTEND-DEPLOYED-URL.com

# ─── FEATURE FLAGS ────────────────────────
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_SENTRY=false

# Optional: Sentry Error Tracking
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
