# ========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ========================================
# IMPORTANT: Copy this to .env and fill in YOUR values
# NEVER commit .env to Git - add it to .gitignore

# ─── SERVER CONFIG ───────────────────────
NODE_ENV=production
PORT=5000
API_BASE_URL=https://YOUR-BACKEND-DEPLOYED-URL.com
FRONTEND_URL=https://YOUR-FRONTEND-DEPLOYED-URL.com

# ─── DATABASE ────────────────────────────
# Get from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/sharemyride?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/sharemyride?retryWrites=true&w=majority

# ─── JWT & SECURITY ──────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=YOUR_64_CHARACTER_RANDOM_STRING_HERE
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=YOUR_64_CHARACTER_RANDOM_STRING_HERE
REFRESH_TOKEN_EXPIRE=30d

# ─── EMAIL SERVICE ───────────────────────

# ✅ OPTION 1: Gmail (Recommended)
# 1. Enable 2FA on Gmail
# 2. Go to myaccount.google.com → Security → App passwords
# 3. Select "Mail" and "Windows Computer"
# 4. Copy the 16-character app password
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=YOUR_16_CHAR_APP_PASSWORD
EMAIL_FROM_NAME=ShareMyRide

# ✅ OPTION 2: Custom SMTP (Uncomment to use)
# EMAIL_SERVICE=custom
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# EMAIL_USER=your-email@your-domain.com
# EMAIL_PASSWORD=your-password

# ─── PAYMENT GATEWAY (Razorpay) ──────────
# Get from: https://dashboard.razorpay.com/settings/api-keys
# ⚠️ USE LIVE KEYS IN PRODUCTION (not TEST keys)
RAZORPAY_KEY_ID=rzp_live_YOUR_KEY_ID_HERE
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET_KEY_HERE

# ─── AWS S3 CONFIGURATION ────────────────
# Get from: AWS Console → IAM → Users → Security Credentials
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# ─── GOOGLE MAPS API ─────────────────────
# Get from: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# ─── TWILIO SMS (Optional) ───────────────
# Get from: https://www.twilio.com/console
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# ─── LOGGING ──────────────────────────────
LOG_LEVEL=info

# ─── FUNCTIONAL TEST USERS ────────────────
TEST_USER_NAME=Test ShareMyRide Driver
TEST_USER_EMAIL=sharemyride.contact@gmail.com
TEST_USER_PASSWORD=ShareMyRide@11
TEST_USER_PHONE=9999999999
TEST_USER_2_NAME=Functional Test Driver
TEST_USER_2_EMAIL=sharemyride.functional@gmail.com
TEST_USER_2_PASSWORD=ShareMyRide@11
TEST_USER_2_PHONE=9999999998
